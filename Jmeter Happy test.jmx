      <hashTree>
        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="Payment templates &amp; settings" enabled="true">
          <stringProp name="delimiter">,</stringProp>
          <stringProp name="fileEncoding">UTF-8</stringProp>
          <stringProp name="filename">/home/rnsxpc/Documents/Projects/HappyJMeter/HappyJmeterTest_SEPA.csv</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <boolProp name="quotedData">false</boolProp>
          <boolProp name="recycle">true</boolProp>
          <stringProp name="shareMode">shareMode.thread</stringProp>
          <boolProp name="stopThread">false</boolProp>
          <stringProp name="variableNames"></stringProp>
          <stringProp name="TestPlan.comments">Test run configuration file with following schema - [RawMessageNoHit, RawMessageHit, Instance, MessageType, Direction, HitProportion]</stringProp>
        </CSVDataSet>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor - random hit/no hit message picker">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.util.concurrent.ThreadLocalRandom

/*
Expected JMeter vars from CSV Data Set Config:
- RawMessageNoHit
- RawMessageHit
- HitProportion

Outputs:
- selectedPayload
- selectedPayloadType   = HIT / NO_HIT
- hitSelected           = true / false
*/

// Parse HitProportion robustly:
// - if 0..1 =&gt; probability directly
// - if 1..100 =&gt; treated as percentage
double parseProbability(String raw) {
    if (raw == null || raw.trim().isEmpty()) {
        return 0.0d
    }

    double v = raw.trim().toDouble()

    if (v &gt; 1.0d) {
        v = v / 100.0d
    }

    if (v &lt; 0.0d) v = 0.0d
    if (v &gt; 1.0d) v = 1.0d

    return v
}

String rawMessageNoHit = vars.get(&quot;RawMessageNoHit&quot;)
String rawMessageHit   = vars.get(&quot;RawMessageHit&quot;)
double hitProbability  = parseProbability(vars.get(&quot;HitProportion&quot;))

boolean useHit = ThreadLocalRandom.current().nextDouble() &lt; hitProbability
String selectedPayload = useHit ? rawMessageHit : rawMessageNoHit

vars.put(&quot;selectedPayload&quot;, selectedPayload ?: &quot;&quot;)
vars.put(&quot;selectedPayloadType&quot;, useHit ? &quot;HIT&quot; : &quot;NO_HIT&quot;)
vars.put(&quot;hitSelected&quot;, String.valueOf(useHit))

// Optional: useful metadata passthrough
vars.put(&quot;selectedInstance&quot;, vars.get(&quot;Instance&quot;) ?: &quot;&quot;)
vars.put(&quot;selectedMessageType&quot;, vars.get(&quot;MessageType&quot;) ?: &quot;&quot;)
vars.put(&quot;selectedDirection&quot;, vars.get(&quot;Direction&quot;) ?: &quot;&quot;)

log.debug(&quot;Payload selected: ${vars.get(&apos;selectedPayloadType&apos;)}, HitProportion=${hitProbability}&quot;)</stringProp>
          <stringProp name="TestPlan.comments">Selects messages given the HitProportion per parameter</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor - build request payload and put into variable (required for AWS signature)">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">// Generate dynamic values if needed
def requestId = UUID.randomUUID().toString()
def timestamp = new Date().format(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ssXXX&quot;)

// Build XML body
def body = &quot;&quot;&quot;
&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;
&lt;Request&gt;
    ${selectedPayload}|${selectedInstance}|${selectedPayloadType}|${selectedDirection}|${selectedMessageType}
&lt;/Request&gt;
&quot;&quot;&quot;

// Store into JMeter variable
vars.put(&quot;request_body&quot;, body)</stringProp>
        </JSR223PreProcessor>
