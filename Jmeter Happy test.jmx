        <hashTree/>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor (AWS Headers)">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.nio.charset.StandardCharsets
import java.security.MessageDigest
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.time.ZonedDateTime
import java.time.ZoneOffset
import java.time.format.DateTimeFormatter
import java.net.URI
import java.net.URLEncoder

// ================================
// Required JMeter variables
// ================================
// aws_access_key
// aws_secret_key
// aws_region
// aws_service
//
// Usually also set:
// aws_method           -&gt; GET / POST / PUT / DELETE ...
// aws_endpoint         -&gt; full URL, e.g. https://execute-api.eu-west-1.amazonaws.com/prod/items?x=1
//
// Optional:
// aws_payload          -&gt; request body as string; default &quot;&quot;
// aws_session_token    -&gt; for temporary credentials only
// aws_signed_headers_extra -&gt; extra canonical headers, one per line, format: header-name:header-value
//                             Example:
//                             content-type:application/json
//                             x-amz-target:SomeService.SomeAction
//
// Outputs created by this script:
// aws_amz_date
// aws_date_stamp
// aws_payload_hash
// aws_canonical_request
// aws_string_to_sign
// aws_signature
// aws_authorization
// aws_host
// aws_canonical_uri
// aws_canonical_querystring

// ================================
// Helpers
// ================================
String sha256Hex(String data) {
    MessageDigest md = MessageDigest.getInstance(&quot;SHA-256&quot;)
    byte[] digest = md.digest(data.getBytes(StandardCharsets.UTF_8))
    return digest.collect { String.format(&quot;%02x&quot;, it) }.join()
}

byte[] hmacSha256(byte[] key, String data) {
    Mac mac = Mac.getInstance(&quot;HmacSHA256&quot;)
    mac.init(new SecretKeySpec(key, &quot;HmacSHA256&quot;))
    return mac.doFinal(data.getBytes(StandardCharsets.UTF_8))
}

String bytesToHex(byte[] bytes) {
    bytes.collect { String.format(&quot;%02x&quot;, it) }.join()
}

// AWS percent-encoding rules for SigV4
String awsEncode(String value, boolean path) {
    String encoded = URLEncoder.encode(value, &quot;UTF-8&quot;)
            .replace(&quot;+&quot;, &quot;%20&quot;)
            .replace(&quot;*&quot;, &quot;%2A&quot;)
            .replace(&quot;%7E&quot;, &quot;~&quot;)
    if (path) {
        encoded = encoded.replace(&quot;%2F&quot;, &quot;/&quot;)
    }
    return encoded
}

// Canonical URI: encode each path segment but preserve /
String canonicalUri(String rawPath) {
    if (rawPath == null || rawPath.isEmpty()) {
        return &quot;/&quot;
    }
    // Encode, preserving slash separators
    return rawPath.split(&quot;/&quot;, -1)
            .collect { awsEncode(it, false) }
            .join(&quot;/&quot;)
            .with { it.startsWith(&quot;/&quot;) ? it : &quot;/&quot; + it }
}

// Canonical query string: sort by encoded key, then encoded value
String canonicalQueryString(String rawQuery) {
    if (rawQuery == null || rawQuery.trim().isEmpty()) {
        return &quot;&quot;
    }

    List&lt;Map&gt; pairs = []
    rawQuery.split(&quot;&amp;&quot;).each { part -&gt;
        String key
        String value
        int idx = part.indexOf(&quot;=&quot;)
        if (idx &gt;= 0) {
            key = part.substring(0, idx)
            value = part.substring(idx + 1)
        } else {
            key = part
            value = &quot;&quot;
        }
        pairs &lt;&lt; [
                k: awsEncode(key, false),
                v: awsEncode(value, false)
        ]
    }

    pairs.sort { a, b -&gt;
        int cmp = a.k &lt;=&gt; b.k
        cmp != 0 ? cmp : (a.v &lt;=&gt; b.v)
    }

    return pairs.collect { &quot;${it.k}=${it.v}&quot; }.join(&quot;&amp;&quot;)
}

// Normalize header value: trim and collapse internal spaces
String normalizeHeaderValue(String s) {
    return s == null ? &quot;&quot; : s.trim().replaceAll(&quot;\\s+&quot;, &quot; &quot;)
}

// ================================
// Read inputs
// ================================
String accessKey    = vars.get(&quot;aws_access_key&quot;)
String secretKey    = vars.get(&quot;aws_secret_key&quot;)
String region       = vars.get(&quot;aws_region&quot;)
String service      = vars.get(&quot;aws_service&quot;)
String method       = vars.get(&quot;aws_method&quot;) ?: &quot;POST&quot;
String endpoint     = vars.get(&quot;aws_endpoint&quot;)
String payload      = vars.get(&quot;request_body&quot;) ?: &quot;&quot;
String sessionToken = vars.get(&quot;aws_session_token&quot;) ?: &quot;&quot;
String extraHeaders = vars.get(&quot;aws_signed_headers_extra&quot;) ?: &quot;&quot;

// Basic validation
if (!accessKey || !secretKey || !region || !service || !endpoint) {
    throw new IllegalArgumentException(
        &quot;Missing one of required vars: aws_access_key, aws_secret_key, aws_region, aws_service, aws_endpoint&quot;
    )
}

// ================================
// Timestamp
// ================================
ZonedDateTime now = ZonedDateTime.now(ZoneOffset.UTC)
String amzDate   = now.format(DateTimeFormatter.ofPattern(&quot;yyyyMMdd&apos;T&apos;HHmmss&apos;Z&apos;&quot;))
String dateStamp = now.format(DateTimeFormatter.ofPattern(&quot;yyyyMMdd&quot;))

// ================================
// Parse URL
// ================================
URI uri = new URI(endpoint)
String host = uri.getHost()
int port = uri.getPort()

// Include port in host only if non-default
String hostHeader = host
if (port != -1 &amp;&amp;
    !((uri.getScheme() == &quot;https&quot; &amp;&amp; port == 443) || (uri.getScheme() == &quot;http&quot; &amp;&amp; port == 80))) {
    hostHeader = &quot;${host}:${port}&quot;
}

String canonicalURI = canonicalUri(uri.getRawPath())
String canonicalQS  = canonicalQueryString(uri.getRawQuery())

// ================================
// Payload hash
// ================================
String payloadHash = sha256Hex(payload)

// ================================
// Canonical headers
// ================================
Map&lt;String, String&gt; headersToSign = new TreeMap&lt;&gt;()

headersToSign[&quot;host&quot;] = hostHeader
headersToSign[&quot;x-amz-date&quot;] = amzDate

if (sessionToken) {
    headersToSign[&quot;x-amz-security-token&quot;] = sessionToken
}

// Add any extra signed headers supplied via JMeter variable
// Format:
// header1:value1
// header2:value2
extraHeaders.split(&quot;\\r?\\n&quot;).each { line -&gt;
    if (line?.trim()) {
        int idx = line.indexOf(&quot;:&quot;)
        if (idx &lt;= 0) {
            throw new IllegalArgumentException(&quot;Invalid aws_signed_headers_extra line: ${line}&quot;)
        }
        String hName = line.substring(0, idx).trim().toLowerCase(Locale.ROOT)
        String hVal  = normalizeHeaderValue(line.substring(idx + 1))
        headersToSign[hName] = hVal
    }
}

// Build canonical headers + signed headers
String canonicalHeaders = headersToSign.collect { k, v -&gt;
    &quot;${k}:${normalizeHeaderValue(v)}\n&quot;
}.join(&quot;&quot;)

String signedHeaders = headersToSign.keySet().join(&quot;;&quot;)

// ================================
// Canonical request
// ================================
String canonicalRequest =
        method.toUpperCase(Locale.ROOT) + &quot;\n&quot; +
        canonicalURI + &quot;\n&quot; +
        canonicalQS + &quot;\n&quot; +
        canonicalHeaders + &quot;\n&quot; +
        signedHeaders + &quot;\n&quot; +
        payloadHash

String algorithm = &quot;AWS4-HMAC-SHA256&quot;
String credentialScope = &quot;${dateStamp}/${region}/${service}/aws4_request&quot;
String stringToSign =
        algorithm + &quot;\n&quot; +
        amzDate + &quot;\n&quot; +
        credentialScope + &quot;\n&quot; +
        sha256Hex(canonicalRequest)

// ================================
// Signing key
// ================================
byte[] kSecret  = (&quot;AWS4&quot; + secretKey).getBytes(StandardCharsets.UTF_8)
byte[] kDate    = hmacSha256(kSecret, dateStamp)
byte[] kRegion  = hmacSha256(kDate, region)
byte[] kService = hmacSha256(kRegion, service)
byte[] kSigning = hmacSha256(kService, &quot;aws4_request&quot;)

String signature = bytesToHex(hmacSha256(kSigning, stringToSign))

String authorizationHeader =
        &quot;${algorithm} &quot; +
        &quot;Credential=${accessKey}/${credentialScope}, &quot; +
        &quot;SignedHeaders=${signedHeaders}, &quot; +
        &quot;Signature=${signature}&quot;

// ================================
// Save outputs for later use
// ================================
vars.put(&quot;aws_amz_date&quot;, amzDate)
vars.put(&quot;aws_date_stamp&quot;, dateStamp)
vars.put(&quot;aws_host&quot;, hostHeader)
vars.put(&quot;aws_payload_hash&quot;, payloadHash)
vars.put(&quot;aws_canonical_uri&quot;, canonicalURI)
vars.put(&quot;aws_canonical_querystring&quot;, canonicalQS)
vars.put(&quot;aws_canonical_request&quot;, canonicalRequest)
vars.put(&quot;aws_string_to_sign&quot;, stringToSign)
vars.put(&quot;aws_signature&quot;, signature)
vars.put(&quot;aws_authorization&quot;, authorizationHeader)

// Optional logging for debug
log.info(&quot;AWS SigV4 generated for endpoint=${endpoint}&quot;)
log.debug(&quot;aws_amz_date=&quot; + amzDate)
log.debug(&quot;aws_authorization=&quot; + authorizationHeader)</stringProp>
          <stringProp name="TestPlan.comments">Generates AWS canonical headers (configure API keys and params in JMeter &quot;AWS signature / header parameters&quot;)</stringProp>
        </JSR223PreProcessor>
