              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="aws_region" elementType="Argument">
              <stringProp name="Argument.name">aws_region</stringProp>
              <stringProp name="Argument.value"></stringProp>
              <stringProp name="Argument.metadata">=</stringProp>
            </elementProp>
            <elementProp name="aws_service" elementType="Argument">
              <stringProp name="Argument.name">aws_service</stringProp>
