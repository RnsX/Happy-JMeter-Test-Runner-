              <stringProp name="Header.value">${aws_signature}</stringProp>
            </elementProp>
            <elementProp name="" elementType="Header">
              <stringProp name="Header.name"></stringProp>
              <stringProp name="Header.value">${aws_authorization}</stringProp>
            </elementProp>
          </collectionProp>
          <stringProp name="TestPlan.comments">Add names specific to the system</stringProp>
        </HeaderManager>
